# ============================================================
# Dockerfile для PHP-приложения Laravel
# ============================================================

# FROM — базовый образ. php:8.4-fpm — официальный образ PHP 8.4
# с FPM (FastCGI Process Manager) для работы с Nginx
# Laravel 12 и его зависимости требуют PHP >= 8.4.1
FROM php:8.4-fpm

# ============================================================
# Системные зависимости
# ============================================================

# apt-get update — обновляем список пакетов
# apt-get install -y — устанавливаем без подтверждения:
#   git         — для Composer (клонирование репозиториев)
#   curl        — HTTP-клиент (нужен многим пакетам)
#   libpng-dev  — библиотека для работы с PNG (расширение gd)
#   libonig-dev — библиотека oniguruma (расширение mbstring)
#   libxml2-dev — XML-библиотека (расширение xml)
#   libpq-dev   — клиентские библиотеки PostgreSQL (расширение pdo_pgsql)
#   zip unzip   — архивы (Composer распаковывает пакеты)
RUN apt-get update && apt-get install -y \
    git \
    curl \
    libpng-dev \
    libonig-dev \
    libxml2-dev \
    libpq-dev \
    zip \
    unzip \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*
# apt-get clean + rm -rf /var/lib/apt/lists/* — чистим кэш apt
# Это уменьшает размер финального Docker-образа

# ============================================================
# PHP-расширения
# ============================================================

# docker-php-ext-install — утилита из базового образа PHP
# устанавливает расширения, скомпилированные специально под эту версию PHP
RUN docker-php-ext-install \
    pdo \
    pdo_pgsql \
    pgsql \
    mbstring \
    exif \
    pcntl \
    bcmath \
    gd

# pdo       — PDO интерфейс для работы с БД
# pdo_pgsql — PDO-драйвер для PostgreSQL (Laravel использует его)
# pgsql     — нативное расширение PostgreSQL
# mbstring  — работа со строками в многобайтных кодировках (UTF-8)
# exif      — чтение EXIF-данных изображений
# pcntl     — управление процессами (нужно для очередей Laravel)
# bcmath    — математика с произвольной точностью
# gd        — обработка изображений (миниатюры, ресайз)

# ============================================================
# Composer
# ============================================================

# Копируем composer из официального образа composer:latest
# --from=composer:latest — multi-stage build: берём файл из другого образа
# /usr/bin/composer — путь в образе composer
# /usr/bin/composer — путь в нашем образе
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# ============================================================
# Рабочая директория
# ============================================================

# WORKDIR — устанавливает рабочую директорию для всех следующих команд
# и для запущенного контейнера
WORKDIR /var/www

# ============================================================
# Права доступа
# ============================================================

# www-data — пользователь, от имени которого работает PHP-FPM и Nginx
# storage/       — Laravel пишет сюда кэш, логи, сессии
# bootstrap/cache — Laravel кэширует конфигурацию
RUN chown -R www-data:www-data /var/www \
    && chmod -R 755 /var/www

# Запускаем PHP-FPM (остаётся в foreground, не демонизируется)
CMD ["php-fpm"]
