APP_NAME="Atlas Software"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------
# PostgreSQL через Docker
# DB_HOST=postgres — имя сервиса в docker-compose.yml
# -----------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=asoft_kz
DB_USERNAME=asoft_user
DB_PASSWORD=secret_password

BROADCAST_DRIVER=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@asoft.kz"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------
# Vite (frontend) — адрес dev-сервера
# -----------------------------------------------
VITE_APP_URL="${APP_URL}"
