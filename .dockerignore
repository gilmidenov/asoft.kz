# ============================================================
# .dockerignore — что НЕ копировать в Docker-образ
# Работает как .gitignore, но для Docker
# Исключаем большие и ненужные папки чтобы ускорить сборку
# ============================================================

# Зависимости (устанавливаются внутри контейнера)
node_modules/
vendor/

# Git
.git/
.gitignore

# Среда разработки
.env
.env.*
!.env.example

# Логи
*.log
docker/nginx/logs/

# Кэш
.phpunit.result.cache
bootstrap/cache/*.php

# Документация (в образе не нужна)
*.md
GUIDE_*.md
